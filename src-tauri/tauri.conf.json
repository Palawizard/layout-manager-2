{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Layout Manager 2",
  "version": "0.1.0",
  "identifier": "com.layoutmanager2.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Layout Manager 2",
        "width": 1100,
        "height": 720,
        "minWidth": 760,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset:; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "copyright": "Layout Manager 2 contributors",
    "shortDescription": "Organisez et appliquez vos espaces de travail Windows.",
    "longDescription": "Layout Manager 2 enregistre des layouts, lance vos applications et place leurs fenêtres sur les bons écrans.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["nsis"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
